# EpiChat .gitignore
# ─────────────────────────────────────────────────────────────

# Raw EEG data (too large for Git — use Git LFS or external storage)
data/raw/
data/processed/*.npy
data/processed/**/*.npy

# Keep directory structure and metadata
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/**/*_meta.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.env

# Node / React
node_modules/
dist/
.next/
.cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Model checkpoints (use Git LFS)
*.ckpt
*.pth
*.pt
*.h5
*.pkl
# Exception: keep the production model weight (only 650KB)
!backend/model_weights/epichat_realistic.pt

# Logs
*.log
logs/

# FastAPI
.env
# Allow production env for Vercel build
!frontend/.env.production
*.db
*.sqlite
